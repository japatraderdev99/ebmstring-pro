---
/**
 * Card de Open Graph (1200×630) — renderizado para /public/og.png via Chrome headless.
 * Rota interna de geração; não linkada.
 */
import "@/styles/global.css";
---

<!doctype html>
<html lang="pt-BR" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow" />
    <title>OG</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;700&family=EB+Garamond:ital@1&family=Saira+Condensed:wght@600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
      html, body { margin: 0; padding: 0; }
      .og {
        width: 1200px;
        height: 630px;
        overflow: hidden;
        position: relative;
        background: #0a0a0a;
      }
    </style>
  </head>
  <body>
    <div class="og flex flex-col justify-center px-20">
      <div class="stringbed absolute inset-0 opacity-[0.16]"></div>
      <div
        class="absolute inset-0"
        style="background: radial-gradient(90% 90% at 80% 20%, rgba(20,58,36,0.6), transparent 55%), radial-gradient(40% 50% at 78% 30%, rgba(156,214,83,0.22), transparent 70%);"
      >
      </div>

      <div class="relative flex items-center gap-12">
        <div class="flex-1">
          <span
            class="tech-label border border-lima/40 bg-quadra/30 px-4 py-2 text-lima"
            style="font-size:15px">Encordoamento de raquetes de tênis · Florianópolis</span
          >
          <h1
            class="mt-6 font-display uppercase text-papel"
            style="font-size:74px; line-height:0.9; letter-spacing:-0.02em;"
          >
            Performance<br /><span class="text-lima italic">começa nas cordas.</span>
          </h1>
          <p class="mt-5 font-body text-muted" style="font-size:22px;">
            Tensão calibrada · cordas premium · agendamento no WhatsApp
          </p>
          <p class="mt-3 font-mono text-faint" style="font-size:18px;">ebmstring.pro</p>
        </div>
        <img src="/ebm-logo.png" alt="EBM String Pro" style="width:300px;" />
      </div>
    </div>
  </body>
</html>
